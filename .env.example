# --- MQTT connection ---
MQTT_HOST=localhost
MQTT_PORT=9001
MQTT_TOPIC=WXSMART/seriennummer/#.   # Seriennummer der Weller X Smart
MQTT_TRANSPORT=websockets
MQTT_KEEPALIVE=60

# --- API server ---
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=0

# --- InfluxDB 2 (optional — leer lassen um zu deaktivieren) ---
# INFLUX_URL=http://localhost:8086
# INFLUX_TOKEN=dein-api-token
# INFLUX_ORG=wxsmart
# INFLUX_BUCKET=soldering

# --- Optional capture helper ---
WXSMART_CAPTURE_SECONDS=45
WXSMART_CAPTURE_DEVICE_PREFIX=WXSMART/seriennummer/
WXSMART_CAPTURE_LOG=temp/wxsmart_live_5min.log

# --- Optional monitor script vars ---
WXSMART_SERIAL=seriennummer
MQTT_MODE=monitor
MQTT_VERBOSE=1
MQTT_COMPACT=1
MQTT_DISCOVERY_SECONDS=10
MQTT_LIVE_IDLE_WARN_SECONDS=12
