# --- MQTT connection ---
MQTT_HOST=localhost
MQTT_PORT=9001
MQTT_TOPIC=WXSMART/1660101260218/#
MQTT_TRANSPORT=websockets
MQTT_KEEPALIVE=60

# --- API server ---
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=0

# --- Optional capture helper ---
WXSMART_CAPTURE_SECONDS=45
WXSMART_CAPTURE_DEVICE_PREFIX=WXSMART/1660101260218/
WXSMART_CAPTURE_LOG=temp/wxsmart_live_5min.log

# --- Optional monitor script vars ---
WXSMART_SERIAL=1660101260218
MQTT_MODE=monitor
MQTT_VERBOSE=1
MQTT_COMPACT=1
MQTT_DISCOVERY_SECONDS=10
MQTT_LIVE_IDLE_WARN_SECONDS=12
